model Model
	culture: es-EC
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["DimCanalDifusion","DimCanalOrigen","DimCarrera","DimComplejidad","DimEstado","DimFacultad","DimFecha","DimKpi","DimPublicoObjetivo","DimSede","DimTipoProducto","DimTipoRequerimiento","DimUsuario","FactAprobacion","FactHistorialEstado","FactKpiResultado","FactProducto","FactRequerimiento","FactSatisfaccion","FactUsoUsuario","_Medidas","ServerName","DatabaseName","EnvironmentName","DimEstadoRequerimiento","DimEstadoProducto"]

annotation __PBI_TimeIntelligenceEnabled = 1

ref table DimCanalDifusion
ref table DimCanalOrigen
ref table DimCarrera
ref table DimComplejidad
ref table DimEstado
ref table DimFacultad
ref table DimFecha
ref table DimKpi
ref table DimPublicoObjetivo
ref table DimSede
ref table DimTipoProducto
ref table DimTipoRequerimiento
ref table DimUsuario
ref table FactAprobacion
ref table FactHistorialEstado
ref table FactKpiResultado
ref table FactProducto
ref table FactRequerimiento
ref table FactSatisfaccion
ref table FactUsoUsuario
ref table _Medidas
ref table DimEstadoRequerimiento
ref table DimEstadoProducto
