      {
        "name": "_Medidas",
        "isHidden": true,
        "columns": [
          {
            "name": "Key",
            "dataType": "string",
            "sourceColumn": "Key",
            "isHidden": true
          }
        ],
        "measures": [
          {
            "name": "Total requerimientos",
            "expression": "COUNTROWS ( FactRequerimiento )",
            "formatString": "0"
          },
          {
            "name": "Total productos",
            "expression": "COUNTROWS ( FactProducto )",
            "formatString": "0"
          },
          {
            "name": "Productos aprobados",
            "expression": "CALCULATE ( [Total productos], FactProducto[EsAprobado] = TRUE () )",
            "formatString": "0"
          },
          {
            "name": "Satisfaccion promedio",
            "expression": "AVERAGE ( FactSatisfaccion[SatisfaccionGeneral] )",
            "formatString": "0.00"
          }
        ],
        "partitions": [
          {
            "name": "_Medidas",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #table(type table [Key = text], {{\"Medidas\"}})",
                "in",
                "    Source"
              ]
            }
          }
        ]
      }
    ]
