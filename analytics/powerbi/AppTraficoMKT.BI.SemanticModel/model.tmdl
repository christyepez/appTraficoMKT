model AppTraficoMKT_BI
    culture: es-EC
    discourageImplicitMeasures

    expression ServerName = "localhost,14333"
        meta [IsParameterQuery=true, Type="Text", IsParameterQueryRequired=true]

    expression DatabaseName = "RequirementsDb"
        meta [IsParameterQuery=true, Type="Text", IsParameterQueryRequired=true]

    expression EnvironmentName = "dev"
        meta [IsParameterQuery=true, Type="Text", IsParameterQueryRequired=true]

    expression Source = Sql.Database(ServerName, DatabaseName, [CreateNavigationProperties=false])

    table _Medidas
        isHidden
        column Key
            dataType: string
            sourceColumn: Key
        partition _Medidas = m
            mode: import
            source =
                let
                    Source = #table(type table [Key = text], {{"Medidas"}})
                in
                    Source

    table DimFecha
        partition DimFecha = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimFecha"]}[Data]

    table DimUsuario
        partition DimUsuario = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimUsuario"]}[Data]

    table DimFacultad
        partition DimFacultad = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimFacultad"]}[Data]

    table DimSede
        partition DimSede = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimSede"]}[Data]

    table DimCarrera
        partition DimCarrera = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimCarrera"]}[Data]

    table DimEstado
        partition DimEstado = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimEstado"]}[Data]

    table DimTipoRequerimiento
        partition DimTipoRequerimiento = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimTipoRequerimiento"]}[Data]

    table DimTipoProducto
        partition DimTipoProducto = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimTipoProducto"]}[Data]

    table DimCanalDifusion
        partition DimCanalDifusion = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimCanalDifusion"]}[Data]

    table DimPublicoObjetivo
        partition DimPublicoObjetivo = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimPublicoObjetivo"]}[Data]

    table DimKpi
        partition DimKpi = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimKpi"]}[Data]

    table DimComplejidad
        partition DimComplejidad = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimComplejidad"]}[Data]

    table DimCanalOrigen
        partition DimCanalOrigen = m
            mode: directQuery
            source = Source{[Schema="bi", Item="DimCanalOrigen"]}[Data]

    table FactRequerimiento
        partition FactRequerimiento = m
            mode: directQuery
            source = Source{[Schema="bi", Item="FactRequerimiento"]}[Data]

    table FactProducto
        partition FactProducto = m
            mode: directQuery
            source = Source{[Schema="bi", Item="FactProducto"]}[Data]

    table FactAprobacion
        partition FactAprobacion = m
            mode: directQuery
            source = Source{[Schema="bi", Item="FactAprobacion"]}[Data]

    table FactHistorialEstado
        partition FactHistorialEstado = m
            mode: directQuery
            source = Source{[Schema="bi", Item="FactHistorialEstado"]}[Data]

    table FactSatisfaccion
        partition FactSatisfaccion = m
            mode: directQuery
            source = Source{[Schema="bi", Item="FactSatisfaccion"]}[Data]

    table FactUsoUsuario
        partition FactUsoUsuario = m
            mode: directQuery
            source = Source{[Schema="bi", Item="FactUsoUsuario"]}[Data]

    table FactKpiResultado
        partition FactKpiResultado = m
            mode: directQuery
            source = Source{[Schema="bi", Item="FactKpiResultado"]}[Data]

    relationship Requerimiento_Producto
        fromColumn: FactProducto.RequerimientoId
        toColumn: FactRequerimiento.RequerimientoId

    relationship Requerimiento_Satisfaccion
        fromColumn: FactSatisfaccion.RequerimientoId
        toColumn: FactRequerimiento.RequerimientoId

    relationship Producto_Aprobacion
        fromColumn: FactAprobacion.ProductoId
        toColumn: FactProducto.ProductoId

    relationship Facultad_Requerimiento
        fromColumn: FactRequerimiento.FacultadId
        toColumn: DimFacultad.FacultadId

    relationship Sede_Requerimiento
        fromColumn: FactRequerimiento.SedeId
        toColumn: DimSede.SedeId

    relationship TipoProducto_Producto
        fromColumn: FactProducto.TipoProductoId
        toColumn: DimTipoProducto.TipoProductoId

    relationship Kpi_Producto
        fromColumn: FactProducto.KpiId
        toColumn: DimKpi.KpiId

    relationship Kpi_Resultado
        fromColumn: FactKpiResultado.KpiId
        toColumn: DimKpi.KpiId
